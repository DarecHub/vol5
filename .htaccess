# Blokovat citlivé soubory
<FilesMatch "^(\.env|\.git|config\.php|functions\.php|install\.php|composer\.(json|lock))$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Security headers (pouze pokud je mod_headers dostupný)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;"
</IfModule>
